# Neon PostgreSQL 接続文字列
# Neon ダッシュボード → Connection Details → Connection string からコピー
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# 為替レート設定 (デフォルト: 160)
DEFAULT_RATE_USD=160
DEFAULT_RATE_EUR=175
DEFAULT_RATE_GBP=205

# アプリパスワード
APP_PASSWORD=naokokenji
